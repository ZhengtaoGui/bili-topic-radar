# AI backend: codex | claude | openai-compatible | auto
# Default is codex. Cloud backends are used only when explicitly selected.
BILI_RADAR_AI_BACKEND=codex

# Claude backend
ANTHROPIC_API_KEY=
BILI_RADAR_CLAUDE_MODEL=claude-opus-4-8

# OpenAI-compatible backend
OPENAI_API_KEY=
BILI_RADAR_OPENAI_MODEL=
BILI_RADAR_OPENAI_BASE_URL=

# Bilibili/network cache and proxy examples
BILI_TOPIC_RADAR_CACHE=
ALL_PROXY=
HTTPS_PROXY=
